{
  "_comment": "Memristor aLIF SNN config. All physical units are explicit in key names.",

  "neuron": {
    "_comment": "Circuit parameters from thyristor hardware reference.",
    "Ra_ohm"      : 2200,
    "Rm_hi_ohm"   : 100000,
    "Rm_lo_ohm"   : 100,
    "Vthresh_V"   : 4.0,
    "Vreset_V"    : 0.0,
    "I_0_uA"      : 15.0,

    "_if_targets" : "Cm and t_ref are SOLVED from these — do not set manually.",
    "I_min_uA"    : 40.0,
    "I_max_uA"    : 100.0,
    "f_min_Hz"    : 70.0,
    "f_max_Hz"    : 200.0
  },

  "synapse": {
    "_comment": "Synaptic RC parameters. tau_s1/tau_s2 = Rs*Cs.",
    "Rs_ohm"      : 10000,
    "Cs_nF"       : 1000,
    "Iw_exc_uA"   : 20.0,
    "Iw_inh_uA"   : 30.0,
    "mode"        : "Is2",
    "_mode_note"  : "'Is1' = exponential/AMPA (feedforward). 'Is2' = alpha/NMDA (recurrent)."
  },

  "network": {
    "_comment": "Defines neuron populations and how they connect.",

    "populations": [
      {
        "name"    : "input",
        "type"    : "PoissonGroup",
        "N"       : 8,
        "_note"   : "One Poisson neuron per input channel (e.g. direction bin)."
      },
      {
        "name"    : "reservoir",
        "type"    : "aLIF",
        "N"       : 20,
        "_note"   : "Recurrent reservoir. Increase N for harder tasks."
      }
    ],

    "connections": [
      {
        "pre"           : "input",
        "post"          : "reservoir",
        "type"          : "exc",
        "rule"          : "all_to_all",
        "weight_scale"  : 1.0,
        "_note"         : "all_to_all, one_to_one, random_p (set p below), or custom matrix."
      },
      {
        "pre"           : "reservoir",
        "post"          : "reservoir",
        "type"          : "exc",
        "rule"          : "random_p",
        "p"             : 0.25,
        "weight_scale"  : 0.6,
        "_note"         : "Sparse recurrent excitatory connections."
      },
      {
        "pre"           : "reservoir",
        "post"          : "reservoir",
        "type"          : "inh",
        "rule"          : "random_p",
        "p"             : 0.15,
        "weight_scale"  : 0.8,
        "_note"         : "Sparse recurrent inhibitory connections (E/I balance)."
      }
    ]
  },

  "learning": {
    "_comment": "Learning rule config. regime is auto-detected from f vs 1/tau_s.",

    "reservoir_readout": {
      "classifier"    : "logistic",
      "_options"      : "logistic, linear_svm, ridge",
      "C"             : 1.0,
      "feature"       : "mean_Is2",
      "_feature_note" : "mean_Is2 = time-average of Is2 per neuron per trial."
    },

    "STDP": {
      "A_plus"        : 0.01,
      "A_minus"       : 0.012,
      "tau_plus_ms"   : 20.0,
      "tau_minus_ms"  : 20.0,
      "w_min"         : 0.0,
      "w_max"         : 2.0
    }
  },

  "simulation": {
    "dt_ms"               : 0.05,
    "trial_duration_ms"   : 300,
    "n_trials_per_class"  : 5,
    "seed"                : 42
  },

  "regime": {
    "_comment": "Auto-detected: if mean_f > 1/tau_s → rate/reservoir. Else → temporal/STDP.",
    "crossover_note": "Crossover frequency = 1/tau_s = 1/(Rs*Cs) = 100 Hz for default params."
  }
}